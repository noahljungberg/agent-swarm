{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/install-path.sh\" || exit 0",
            "timeout": 5,
            "statusMessage": "Linking agent-swarm CLI..."
          }
        ]
      }
    ]
  }
}
